{
    "compilerOptions": {
        "strict": true,
        "target": "ESNext",
        "module": "ESNext",
        "outDir": "dist",
        "rootDir": "src",
        "declaration": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "moduleResolution": "bundler",
        "emitDeclarationOnly": true,
        "lib": [
            "DOM",
            "ESNext"
        ],
        "types": [
            "node"
        ],
        "paths": {
            "@services/*": [
                "./src/services/*"
            ],
            "@providers/*": [
                "./src/providers/*"
            ],
            "@components/*": [
                "./src/components/*"
            ]
        }
    },
    "include": [
        "src/index.ts"
    ],
    "exclude": [
        "dist",
        "node_modules",
        "**/*.spec.ts"
    ],
    "references": [
        { "path": "./tsconfig.spec.json" }
    ]
}
