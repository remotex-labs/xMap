{
    "name": "@remotex-labs/xmap",
    "main": "dist/cjs/index.js",
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "dist/esm/index.js",
    "author": "Garefild",
    "version": "1.0.0-local",
    "license": "Mozilla Public License Version 2.0",
    "homepage": "https://remotex-labs.github.io/xMap/",
    "description": "A library with a sourcemap parser and TypeScript code formatter for the CLI",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        },
        "./parser.component": {
            "types": "./dist/parser.component.d.ts",
            "import": "./dist/esm/parser.component.js",
            "require": "./dist/cjs/parser.component.js"
        },
        "./formatter.component": {
            "types": "./dist/formatter.component.d.ts",
            "import": "./dist/esm/formatter.component.js",
            "require": "./dist/cjs/formatter.component.js"
        },
        "./highlighter.component": {
            "types": "./dist/highlighter.component.d.ts",
            "import": "./dist/esm/highlighter.component.js",
            "require": "./dist/cjs/highlighter.component.js"
        },
        "./package.json": "./package.json"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/remotex-lab/xMap.git"
    },
    "bugs": {
        "url": "https://github.com/remotex-lab/xMap/issues"
    },
    "keywords": [
        "cli",
        "xMap",
        "xmap",
        "parser",
        "formatter",
        "debugging",
        "sourcemap",
        "source-map",
        "highlighter",
        "developer-tools"
    ],
    "engines": {
        "node": ">=20"
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "scripts": {
        "dev":              "xBuild -w",
        "build":            "xBuild",
        "build:clean":      "rm -rf ./dist && xBuild",

        "test":             "xjet",
        "test:coverage":    "xjet --coverage",

        "lint":             "pnpm lint:md && pnpm lint:eslint && pnpm lint:typescript",
        "lint:md":          "markdownlint \"**/*.md\" --ignore node_modules",
        "lint:eslint":      "eslint . -c ./eslint.config.mjs",
        "lint:typescript":  "xBuild --tc",

        "docs:dev":         "vitepress dev docs",
        "docs:build":       "vitepress build docs",
        "docs:preview":     "vitepress preview docs",

        "ci":              "pnpm lint && pnpm test && pnpm build:clean",
        "prepublishOnly":  "pnpm lint && pnpm test && pnpm build:clean"
    },
    "devDependencies": {
        "eslint": "^10.1.0",
        "vitepress": "^2.0.0-alpha.15",
        "markdownlint-cli": "^0.48.0",
        "typescript-eslint": "^8.57.2",
        "eslint-plugin-tsdoc": "^0.5.2",
        "@types/node": "^25.5.0",
        "@remotex-labs/xjet": "^1.5.4",
        "@viteplus/versions": "^2.0.6",
        "@remotex-labs/xbuild": "^2.2.4",
        "eslint-plugin-perfectionist": "^5.7.0"
    },
    "dependencies": {
        "typescript": "6.0.2",
        "@remotex-labs/xansi": "^1.3.7"
    }
}
